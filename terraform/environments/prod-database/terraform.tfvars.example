aws_region = "ap-south-1"
project_name = "hospital-mgmt"

vpc_id = "vpc-xxxxxxxx"
private_subnet_ids = ["subnet-xxxxxxxx", "subnet-yyyyyyyy"]
allowed_cidr_blocks = ["10.30.0.0/16"]

db_username = "adminuser"
db_password = "REPLACE_ME"

engine = "sqlserver-se"
# Optional: set only when you need a specific supported version in your region.
# engine_version = "15.00.xxxx.x.v1"
instance_class = "db.m5.large"
allocated_storage = 100
multi_az = true
backup_retention_period = 14
deletion_protection = true
publicly_accessible = false
